# Model selection. Both agents share CRUCIBLE_MODEL by default.
# Set CRUCIBLE_MODEL_A and/or CRUCIBLE_MODEL_B to override per agent and run cross-model matchups
# (e.g. CRUCIBLE_MODEL_A=claude-opus-4-7 CRUCIBLE_MODEL_B=gpt-5.5).
CRUCIBLE_MODEL=claude-opus-4-7
# CRUCIBLE_MODEL_A=claude-opus-4-7
# CRUCIBLE_MODEL_B=gpt-5.5

# Provider API keys (set the keys for whichever providers your selected models use)
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# Experiment config (optional, CLI flags override these)
CRUCIBLE_PROMPT_MODE=balanced_competitive
CRUCIBLE_PSYCHOLOGY_BLOCK=on
CRUCIBLE_DECEPTION_POLICY=explicit

# Observability (optional, disabled by default)
DD_API_KEY=your_datadog_key_here
BRAINTRUST_API_KEY=your_braintrust_key_here

# Voice synthesis (optional, for demo)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
