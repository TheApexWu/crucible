# Model selection (overrides GEMINI_MODEL)
CRUCIBLE_MODEL=gemini-2.5-flash

# Provider API keys (only need the one matching your model)
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Experiment config (optional, CLI flags override these)
CRUCIBLE_PROMPT_MODE=balanced_competitive
CRUCIBLE_PSYCHOLOGY_BLOCK=on
CRUCIBLE_DECEPTION_POLICY=explicit

# Observability (optional, disabled by default)
DD_API_KEY=your_datadog_key_here
BRAINTRUST_API_KEY=your_braintrust_key_here

# Voice synthesis (optional, for demo)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
